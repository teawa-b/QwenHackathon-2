# Copy this file to .env on the Alibaba Cloud instance.
# Never commit the real key.
DASHSCOPE_API_KEY=sk-your-qwen-cloud-key
ALIBABA_CLOUD_REGION=ap-southeast-1
DEPLOYMENT_COMMIT=replace-with-git-commit

# Optional model overrides
# QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com
# QWEN_TEXT_MODEL=qwen3.7-plus
# QWEN_ASR_MODEL=qwen3-asr-flash
# QWEN_IMAGE_MODEL=qwen-image-2.0-pro
