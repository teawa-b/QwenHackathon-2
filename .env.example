# Qwen Cloud (Alibaba Cloud Model Studio) — required for live mode.
# Without it the app runs honestly in demo-catalogue mode.
DASHSCOPE_API_KEY=

# Optional overrides (defaults shown)
# QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com
# QWEN_TEXT_MODEL=qwen3.7-plus
# QWEN_ASR_MODEL=qwen3-asr-flash
# QWEN_IMAGE_MODEL=qwen-image-2.0-pro
# QWEN_IMAGE_SIZE=1328*1328

# Deployment metadata exposed by /api/health (never put secrets here)
# DEPLOYMENT_PROVIDER=Alibaba Cloud ECS/SAS
# DEPLOYMENT_REGION=ap-southeast-1
# DEPLOYMENT_COMMIT=git-commit-sha

# Server port (Railway injects PORT automatically; Docker defaults to 8787)
# PORT=8787
